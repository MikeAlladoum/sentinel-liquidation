# Configuration Stagenet — Sentinel de Liquidation

# URL RPC du Stagenet (fourni lors de la création): https://contract.dev
# Format: https://stagenet-...-rpc.contract.dev
STAGENET_RPC_URL=https://your-stagenet-rpc-url-here

# Chain ID du Stagenet (généralement 1 si fork Ethereum mainnet)
STAGENET_CHAIN_ID=1

# Clé privée du wallet de déploiement
# ⚠️ JAMAIS committer cette clé en prod!
# Obtenir une adresse de test depuis le faucet Stagenet dans https://contract.dev
PRIVATE_KEY=your_private_key_without_0x_prefix

# Adresse du contrat LiquidationSentinel après déploiement
# (Rempli après npx hardhat run deploy.js)
SENTINEL_ADDRESS=0x...

# Optionnel : API keys pour vérification/exploration
# ETHERSCAN_API_KEY=...
# INFURA_API_KEY=...
