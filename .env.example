# Stagenet Configuration — Sentinel de Liquidation

# Stagenet RPC URL (provided when creating Stagenet): https://contract.dev
# Format: https://stagenet-...-rpc.contract.dev
STAGENET_RPC_URL=https://your-stagenet-rpc-url-here

# Chain ID of Stagenet (typically 1 if forking Ethereum mainnet)
STAGENET_CHAIN_ID=1

# Private key of deployment wallet
# ⚠️ NEVER commit this key in production!
# Get a test address from Stagenet faucet at https://contract.dev
PRIVATE_KEY=your_private_key_without_0x_prefix

# Address of LiquidationSentinel contract after deployment
# (Filled after npx hardhat run deploy.js)
SENTINEL_ADDRESS=0x...

# Optional: API keys for verification/exploration
# ETHERSCAN_API_KEY=...
# INFURA_API_KEY=...
